<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.1" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_1.xsd">
    <servlet>
        <servlet-name>Acceso</servlet-name>
        <servlet-class>controller.Acceso</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TiendaController</servlet-name>
        <servlet-class>controller.TiendaController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProcesarPedido</servlet-name>
        <servlet-class>controller.ProcesarPedido</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Acceso</servlet-name>
        <url-pattern>/Acceso</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TiendaController</servlet-name>
        <url-pattern>/TiendaController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProcesarPedido</servlet-name>
        <url-pattern>/ProcesarPedido</url-pattern>
    </servlet-mapping>
</web-app>
